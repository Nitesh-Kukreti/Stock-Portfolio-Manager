
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User { // it is a table
  id           String   @id @default(uuid())
  email        String   @unique
  fullName     String
  passwordHash String   // To store the encrypted password
  isVerified   Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  verifications Verification[]
}

model Verification {
  id String @id @default(uuid())
  hashedCode String 
  type VerificationType @default(EMAIL_VERIFY)
  attempts Int @default(0)
  expiresAt DateTime 
  createdAt DateTime @default(now())

  // Foreign Key to User
  userId String 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId]) // For faster lookups
}

enum VerificationType {
  EMAIL_VERIFY
  PASSWORD_RESET
  EMAIL_CHANGE
}