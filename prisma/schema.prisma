
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User { // it is a table
  id           String   @id @default(uuid())
  email        String   @unique
  fullName     String
  passwordHash String   // To store the encrypted password
  isVerified   Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  verifications Verification[]
}

model Verification {
  id          String   @id @default(uuid())
  hashedCode  String
  type        VerificationType @default(VERIFY_EMAIL)
  attempts    Int      @default(0)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  // Foreign Key to User via email
  email       String
  user        User     @relation(fields: [email], references: [email], onDelete: Cascade)

  @@index([email])
}

enum VerificationType {
  VERIFY_EMAIL
  RESET_PASSWORD
  CHANGE_EMAIL
}