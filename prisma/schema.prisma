
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User { // it is a table
  id           String   @id @default(uuid())
  email        String   @unique
  fullName     String
  passwordHash String   // To store the encrypted password
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}